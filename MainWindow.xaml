<Window x:Class="testRepo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transaction Log Patcher" Height="430" Width="820"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="120"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,10">Folder Path</TextBlock>
        <TextBox x:Name="FolderPathTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,8,10" IsReadOnly="True"/>
        <Button Grid.Row="0" Grid.Column="2" Margin="0,0,0,10" Click="BrowseFolder_Click">Browse...</Button>

        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,10">Transaction Type</TextBlock>
        <ComboBox x:Name="TransactionTypeComboBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10" SelectedIndex="0">
            <ComboBoxItem Content="loyalty"/>
            <ComboBoxItem Content="walletReloadByEbanking"/>
            <ComboBoxItem Content="walletReloadByCard"/>
        </ComboBox>

        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,10">Expected Request Field</TextBlock>
        <TextBox x:Name="ExpectedFieldTextBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10" IsReadOnly="True"/>

        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,10">DB Connection</TextBlock>
        <TextBox x:Name="ConnectionStringTextBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10"
                 Text="Server=.;Database=YourDb;Trusted_Connection=True;TrustServerCertificate=True;"/>

        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Top" Margin="0,0,8,0">Output Log</TextBlock>
        <TextBox x:Name="OutputTextBox" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" AcceptsReturn="True"/>

        <Button Grid.Row="5" Grid.Column="2" Margin="0,12,0,0" Height="32" Click="RunButton_Click">Run Check</Button>
    </Grid>
</Window>
